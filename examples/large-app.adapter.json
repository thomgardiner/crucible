{
  "repo": "my-app",
  "_note": "Reference adapter for a large multi-crate app. Paths use .crucible/; point gateRunner at your real verify entry.",
  "charter": ".crucible/charter.json",
  "approvals": ".crucible/approvals.json",
  "gateRunner": {
    "command": "make verify",
    "file": "scripts/verify.ps1",
    "checkerPattern": "node (scripts/check-[a-z-]+\\.mjs)"
  },
  "changeToUnits": "tools/test-impact.mjs",
  "highRiskUnits": [
    "payments",
    "auth",
    "checkout"
  ],
  "prePush": ".githooks/pre-push",
  "pinnedConfig": [
    ".crucible/adapter.json",
    ".crucible/mutation.json",
    ".crucible/acceptance.json",
    ".crucible/mutation-waivers.json"
  ]
}
