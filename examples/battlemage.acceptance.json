{
  "_note": "Reference acceptance recipe for a large Rust + frontend desktop app. Boot/drive commands are illustrative — replace with your real build, readiness oracle, and end-to-end drives. Only the canonical .crucible/acceptance.json path certifies.",
  "repo": "battlemage",
  "build": {
    "cmd": "npm --prefix frontend run build && cargo build -p battlemage --features webview-e2e",
    "timeoutSec": 1800
  },
  "boot": {
    "cmd": "pwsh -NoProfile -File scripts/run-native-feature-e2e.ps1",
    "timeoutSec": 600,
    "oracle": { "stdoutForbid": "panicked|thread 'main'|DB-OPEN-FAILED" }
  },
  "drive": [
    {
      "name": "checkout-replay",
      "cmd": "cargo nextest run -p e2e --features harness -E 'test(checkout_flow)'",
      "timeoutSec": 600,
      "oracle": { "stdoutMatch": "1 passed|tests run: 1" }
    },
    {
      "name": "production-flow-matrix",
      "cmd": "cargo nextest run -p e2e --features harness -E 'test(production_flow_matrix)'",
      "timeoutSec": 900,
      "oracle": { "stdoutForbid": "FAILED|panicked" }
    }
  ],
  "trust": {
    "testRoots": ["crates", "frontend/tests", "frontend/src", "src-tauri"],
    "testPattern": "(\\.test\\.[tj]sx?$|\\.spec\\.[tj]sx?$|_tests?\\.rs$|/tests?\\.rs$)",
    "mockMarkers": ["mockIPC(", "renderWithProviders", "open_in_memory", "wiremock", "MockServer"]
  }
}
